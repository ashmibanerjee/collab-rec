# Required for Gemini models via google-adk
GOOGLE_API_KEY=

# Required only if using Vertex-backed models (e.g., Claude through Vertex)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-east5
VERTEXAI_LOCATION=us-east5

# Optional, depending on model/provider routing
ANTHROPIC_API_KEY=

